rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Locations - Anyone can read, authenticated users can write
    match /locations/{document=**} {
      allow read: if true;
      allow write: if request.auth != null || request.time < timestamp.date(2026, 3, 1);
    }
    
    // Buses - Anyone can read, authenticated users can write
    match /buses/{document=**} {
      allow read: if true;
      allow write: if request.auth != null || request.time < timestamp.date(2026, 3, 1);
    }
  }
}
